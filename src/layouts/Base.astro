---
import SEOHead from '../components/SEOHead.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  ogType?: string;
  structuredData?: object | object[];
  noindex?: boolean;
}

const { title, description, ogImage, ogType, structuredData, noindex } = Astro.props;

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || '';

const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'ExerciseGym',
  name: 'Core & Balance Pilates Studio',
  url: siteUrl,
  telephone: '+1-512-555-0184',
  email: 'hello@coreandbalanceatx.com',
  address: {
    '@type': 'PostalAddress',
    streetAddress: '2114 South Lamar Blvd, Suite 210',
    addressLocality: 'Austin',
    addressRegion: 'TX',
    postalCode: '78704',
    addressCountry: 'US',
  },
  areaServed: 'Austin, TX',
  priceRange: '$$',
  openingHours: ['Mo-Fr 06:00-20:00', 'Sa-Su 08:00-14:00'],
};

const baseSchemas = Array.isArray(structuredData) ? structuredData : structuredData ? [structuredData] : [];
const allSchemas = [...baseSchemas, localBusiness];

const nav = [
  { href: '/classes', label: 'Classes' },
  { href: '/schedule', label: 'Schedule' },
  { href: '/instructors', label: 'Instructors' },
  { href: '/pricing', label: 'Pricing' },
];
const path = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <SEOHead {title} {description} {ogImage} {ogType} structuredData={allSchemas} {noindex} />
  </head>
  <body class="min-h-screen flex flex-col">
    <header id="site-header" class="sticky top-0 z-50 bg-paper/90 backdrop-blur-sm transition-shadow border-b border-transparent [&.scrolled]:border-line">
      <div class="mx-auto max-w-6xl px-6 py-4 flex items-center justify-between gap-6">
        <a href="/" class="flex items-baseline gap-2 shrink-0">
          <span class="font-display text-xl leading-none tracking-tight text-ink">Core <span class="text-sage">&amp;</span> Balance</span>
          <span class="hidden sm:inline text-[11px] uppercase tracking-[0.18em] text-muted">Pilates · Austin</span>
        </a>
        <nav class="hidden md:flex items-center gap-7 text-sm" aria-label="Primary">
          {nav.map((n) => (
            <a
              href={n.href}
              class:list={[
                'transition-colors hover:text-sage',
                path.startsWith(n.href) ? 'text-sage font-medium' : 'text-ink/80',
              ]}
            >{n.label}</a>
          ))}
        </nav>
        <div class="flex items-center gap-3">
          <a href="/book" class="inline-flex items-center rounded-full bg-sage px-5 py-2.5 text-sm font-medium text-paper transition-colors hover:bg-sage-dark">Book a class</a>
          <button id="menu-btn" class="md:hidden p-2 -mr-2 text-ink" aria-label="Open menu" aria-expanded="false">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 7h16M4 12h16M4 17h16"/></svg>
          </button>
        </div>
      </div>
      <div id="mobile-menu" class="hidden md:hidden border-t border-line bg-paper px-6 py-4">
        <nav class="flex flex-col gap-4 text-sm" aria-label="Mobile">
          {nav.map((n) => <a href={n.href} class="text-ink/80 hover:text-sage">{n.label}</a>)}
          <a href="/testimonials" class="text-ink/80 hover:text-sage">Testimonials</a>
          <a href="/contact" class="text-ink/80 hover:text-sage">Contact</a>
        </nav>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-line bg-cream">
      <div class="mx-auto max-w-6xl px-6 py-14 grid gap-10 md:grid-cols-4">
        <div class="md:col-span-2 max-w-sm">
          <p class="font-display text-lg text-ink">Core <span class="text-sage">&amp;</span> Balance Pilates Studio</p>
          <p class="mt-3 text-sm leading-relaxed text-muted">Boutique reformer, mat, and prenatal pilates in South Austin. Small classes, expert instructors, and a studio that feels like a deep breath.</p>
          <address class="mt-4 text-sm not-italic leading-relaxed text-muted">
            2114 South Lamar Blvd, Suite 210<br />
            Austin, TX 78704<br />
            <a href="tel:+15125550184" class="hover:text-sage">(512) 555-0184</a> · <a href="mailto:hello@coreandbalanceatx.com" class="hover:text-sage">hello@coreandbalanceatx.com</a>
          </address>
        </div>
        <div>
          <p class="text-[11px] uppercase tracking-[0.18em] text-muted">Classes</p>
          <ul class="mt-3 space-y-2 text-sm">
            <li><a href="/classes/reformer-pilates" class="hover:text-sage">Reformer pilates</a></li>
            <li><a href="/classes/mat-pilates" class="hover:text-sage">Mat pilates</a></li>
            <li><a href="/classes/prenatal-pilates" class="hover:text-sage">Prenatal pilates</a></li>
            <li><a href="/classes/barre-fusion" class="hover:text-sage">Barre fusion</a></li>
            <li><a href="/classes/private-sessions" class="hover:text-sage">Private sessions</a></li>
          </ul>
        </div>
        <div>
          <p class="text-[11px] uppercase tracking-[0.18em] text-muted">Studio</p>
          <ul class="mt-3 space-y-2 text-sm">
            <li><a href="/schedule" class="hover:text-sage">Class schedule</a></li>
            <li><a href="/instructors" class="hover:text-sage">Instructors</a></li>
            <li><a href="/pricing" class="hover:text-sage">Pricing</a></li>
            <li><a href="/testimonials" class="hover:text-sage">Testimonials</a></li>
            <li><a href="/about" class="hover:text-sage">About us</a></li>
            <li><a href="/contact" class="hover:text-sage">Contact</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-line">
        <div class="mx-auto max-w-6xl px-6 py-5 flex flex-col sm:flex-row justify-between gap-2 text-xs text-muted">
          <p>© 2026 Core &amp; Balance Pilates Studio. All rights reserved.</p>
          <p>Open Mon–Fri 6am–8pm · Sat–Sun 8am–2pm</p>
        </div>
      </div>
    </footer>

    <script>
      const header = document.getElementById('site-header');
      const onScroll = () => header?.classList.toggle('scrolled', window.scrollY > 24);
      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();
      const btn = document.getElementById('menu-btn');
      const menu = document.getElementById('mobile-menu');
      btn?.addEventListener('click', () => {
        const open = menu?.classList.toggle('hidden') === false;
        btn.setAttribute('aria-expanded', String(open));
      });
    </script>
  </body>
</html>
