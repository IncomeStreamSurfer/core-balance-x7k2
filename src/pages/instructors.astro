---
import Base from '../layouts/Base.astro';
import { anonClient } from '../lib/supabase';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || '';
const sb = anonClient();

let instructors: any[] = [];
if (sb) {
  const { data } = await sb
    .from('instructors')
    .select('slug, name, role, bio, certifications, specialties, image_url')
    .not('published_at', 'is', null)
    .order('sort_order');
  instructors = data ?? [];
}

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Instructors', item: `${siteUrl}/instructors` },
    ],
  },
  ...instructors.map((p) => ({
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: p.name,
    jobTitle: p.role,
    worksFor: { '@type': 'LocalBusiness', name: 'Core & Balance Pilates Studio' },
    url: `${siteUrl}/instructors#${p.slug}`,
  })),
];
---

<Base
  title="Pilates Instructors Austin | Core & Balance Studio"
  description="Meet the certified pilates instructors behind Core & Balance — reformer, mat, prenatal, and rehab specialists in Austin, TX."
  structuredData={schemas}
>
  <section class="mx-auto max-w-6xl px-6 pt-16 pb-12 lg:pt-24">
    <p class="text-[11px] uppercase tracking-[0.22em] text-sage font-medium">The team</p>
    <h1 class="mt-4 font-display text-4xl sm:text-5xl tracking-[-0.02em] leading-[1.02] text-ink max-w-2xl">Meet our pilates instructors</h1>
    <p class="mt-5 max-w-2xl text-muted leading-relaxed">
      Every pilates instructor at our Austin studio holds a comprehensive certification — the 450+ hour kind, not the weekend-workshop kind — and most bring a specialty on top: sports rehab, prenatal movement, or post-surgery recovery. Find them on the <a href="/schedule" class="text-sage underline decoration-line underline-offset-4 hover:decoration-sage">weekly schedule</a>, or work with one directly in a <a href="/classes/private-sessions" class="text-sage underline decoration-line underline-offset-4 hover:decoration-sage">private session</a>.
    </p>
  </section>

  <section class="mx-auto max-w-6xl px-6 pb-20 lg:pb-28 space-y-16">
    {instructors.map((p, idx) => (
      <article id={p.slug} class:list={['grid gap-8 lg:gap-14 lg:grid-cols-[380px_1fr] items-start scroll-mt-28', idx % 2 === 1 && 'lg:grid-cols-[1fr_380px]']}>
        <div class:list={['aspect-[6/7] overflow-hidden rounded-lg max-w-md', idx % 2 === 1 && 'lg:order-last']}>
          <img src={p.image_url} alt={`${p.name}, ${p.role} at Core & Balance Pilates Studio in Austin`} class="h-full w-full object-cover" width="600" height="700" loading={idx === 0 ? 'eager' : 'lazy'} />
        </div>
        <div>
          <h2 class="font-display text-3xl tracking-tight text-ink">{p.name}</h2>
          <p class="mt-1 text-sage font-medium">{p.role}</p>
          <p class="mt-5 max-w-xl leading-relaxed text-ink/85">{p.bio}</p>
          <div class="mt-6 grid gap-4 sm:grid-cols-2 max-w-xl">
            <div class="rounded-lg border border-line bg-cream p-4">
              <p class="text-[11px] uppercase tracking-[0.16em] text-muted">Certifications</p>
              <ul class="mt-2 space-y-1 text-sm text-ink">
                {(p.certifications ?? []).map((c: string) => <li>· {c}</li>)}
              </ul>
            </div>
            <div class="rounded-lg border border-line bg-cream p-4">
              <p class="text-[11px] uppercase tracking-[0.16em] text-muted">Specialties</p>
              <ul class="mt-2 space-y-1 text-sm text-ink">
                {(p.specialties ?? []).map((s: string) => <li>· {s}</li>)}
              </ul>
            </div>
          </div>
          <a href="/schedule" class="mt-6 inline-block text-sm font-medium text-sage underline decoration-line underline-offset-4 hover:decoration-sage">See {p.name.split(' ')[0]}'s classes this week →</a>
        </div>
      </article>
    ))}
  </section>

  <section class="border-t border-line bg-cream">
    <div class="mx-auto max-w-6xl px-6 py-16 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-6">
      <div>
        <h2 class="font-display text-2xl sm:text-3xl tracking-tight text-ink">Take a class with the team</h2>
        <p class="mt-2 text-muted">Book online — first-timers welcome in every All Levels class.</p>
      </div>
      <a href="/book" class="inline-flex items-center rounded-full bg-sage px-7 py-3.5 text-[15px] font-medium text-paper transition-all hover:bg-sage-dark hover:-translate-y-0.5 shrink-0">Book a class</a>
    </div>
  </section>
</Base>
