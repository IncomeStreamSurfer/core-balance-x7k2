---
import Base from '../../layouts/Base.astro';
import { anonClient } from '../../lib/supabase';

const siteUrl = Astro.site?.toString().replace(/\/$/, '') || '';
const sb = anonClient();

let classes: any[] = [];
if (sb) {
  const { data } = await sb
    .from('classes')
    .select('slug, name, short_description, level, duration_minutes, price_cents, capacity, image_url')
    .not('published_at', 'is', null)
    .order('sort_order');
  classes = data ?? [];
}

const schemas = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Pilates Classes in Austin',
    url: `${siteUrl}/classes`,
    mainEntity: {
      '@type': 'ItemList',
      itemListElement: classes.map((c, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        url: `${siteUrl}/classes/${c.slug}`,
        name: c.name,
      })),
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: siteUrl },
      { '@type': 'ListItem', position: 2, name: 'Classes', item: `${siteUrl}/classes` },
    ],
  },
];
---

<Base
  title="Pilates Class Types | Core & Balance Studio"
  description="From reformer to prenatal pilates, find the perfect class for your goals. Browse all class types and book online."
  structuredData={schemas}
>
  <section class="mx-auto max-w-6xl px-6 pt-16 pb-10 lg:pt-24">
    <p class="text-[11px] uppercase tracking-[0.22em] text-sage font-medium">Classes</p>
    <h1 class="mt-4 font-display text-4xl sm:text-5xl tracking-[-0.02em] leading-[1.02] text-ink max-w-2xl">Explore our pilates classes</h1>
    <div class="mt-6 max-w-2xl space-y-4 text-muted leading-relaxed">
      <p>
        Every pilates class in Austin promises "core strength". Ours are built so you actually feel it — small groups, comprehensively certified instructors, and five distinct formats that cover everything from your first day on a mat to one-on-one rehab work. Whether you're chasing better posture, training around an injury, or preparing for a birth, there's a class here shaped for exactly that.
      </p>
      <p>
        Not sure where to start? Beginners usually love <a href="/classes/mat-pilates" class="text-sage underline decoration-line underline-offset-4 hover:decoration-sage">mat pilates</a>, most members graduate to the <a href="/classes/reformer-pilates" class="text-sage underline decoration-line underline-offset-4 hover:decoration-sage">reformer</a>, and anyone with a specific goal should look at <a href="/classes/private-sessions" class="text-sage underline decoration-line underline-offset-4 hover:decoration-sage">private sessions</a>. Every class is bookable online from the <a href="/schedule" class="text-sage underline decoration-line underline-offset-4 hover:decoration-sage">weekly schedule</a>.
      </p>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 pb-20 lg:pb-28">
    <div class="grid gap-8 md:grid-cols-2">
      {classes.map((c, idx) => (
        <a href={`/classes/${c.slug}`} class:list={['group grid gap-0 overflow-hidden rounded-lg border border-line bg-paper transition-all hover:-translate-y-0.5 hover:shadow-sm', idx === 0 && 'md:col-span-2 md:grid-cols-2']}>
          <div class:list={['overflow-hidden', idx === 0 ? 'aspect-[4/3] md:aspect-auto' : 'aspect-[10/6]']}>
            <img src={c.image_url} alt={`${c.name} class at Core & Balance Pilates Studio in Austin`} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]" width="1000" height="700" loading={idx === 0 ? 'eager' : 'lazy'} />
          </div>
          <div class="p-7 flex flex-col">
            <div class="flex items-center gap-3 text-[11px] uppercase tracking-[0.16em] text-sage">
              <span>{c.level}</span><span class="text-line">·</span><span>{c.duration_minutes} min</span><span class="text-line">·</span><span>max {c.capacity}</span>
            </div>
            <h2 class="mt-3 font-display text-2xl text-ink group-hover:text-sage-dark">{c.name}</h2>
            <p class="mt-2 text-sm leading-relaxed text-muted">{c.short_description}</p>
            <p class="mt-auto pt-5 text-sm font-medium text-ink">
              ${(c.price_cents / 100).toFixed(0)} per class
              <span class="ml-3 text-sage underline decoration-line underline-offset-4 group-hover:decoration-sage">Learn more →</span>
            </p>
          </div>
        </a>
      ))}
    </div>
    <div class="mt-14 flex flex-wrap items-center gap-5 border-t border-line pt-8">
      <a href="/book" class="inline-flex items-center rounded-full bg-sage px-7 py-3.5 text-[15px] font-medium text-paper transition-all hover:bg-sage-dark hover:-translate-y-0.5">Book a class online</a>
      <a href="/pricing" class="text-sm font-medium text-ink underline decoration-line underline-offset-4 hover:text-sage hover:decoration-sage">See pricing</a>
    </div>
  </section>
</Base>
